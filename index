/* ===== TOAST / FX ===== */
.toast-zone{position:fixed;top:150px;left:50%;transform:translateX(-50%);pointer-events:none;z-index:1000;display:flex;flex-direction:column;gap:10px;align-items:center;}
.toast{
  background:var(--lego-yellow);color:var(--lego-black);
  padding:14px 28px;border:4px solid var(--lego-black);border-radius:14px;
  font-family:'Lilita One',sans-serif;font-size:18px;letter-spacing:2px;
  box-shadow:inset 0 -6px 0 rgba(0,0,0,.18), inset 0 3px 0 rgba(255,255,255,.4), 0 6px 0 var(--lego-red), 0 12px 24px rgba(0,0,0,.5);
  animation:pop 1.8s ease-out forwards;text-align:center;
}
.toast.bad{background:var(--lego-red);color:var(--lego-white);}
.toast.gold{background:var(--lego-green);color:var(--lego-white);font-size:22px;}
@keyframes pop{
  0%{transform:scale(.3) rotate(-8deg);opacity:0;}
  15%{transform:scale(1.2) rotate(2deg);opacity:1;}
  30%{transform:scale(1) rotate(-1deg);}
  85%{opacity:1;transform:translateY(0) scale(1);}
  100%{opacity:0;transform:translateY(-50px) scale(.9);}
}

.desk.levelup{animation:levelup 1.2s ease-out;z-index:10;}
@keyframes levelup{
  0%{box-shadow:0 0 0 0 var(--saber-green), 0 4px 0 rgba(0,0,0,.5);}
  30%{box-shadow:0 0 0 20px var(--saber-green), 0 4px 0 rgba(0,0,0,.5), 0 0 40px var(--saber-green);transform:scale(1.15);}
  60%{box-shadow:0 0 0 32px transparent, 0 4px 0 rgba(0,0,0,.5);transform:scale(1.04);}
  100%{box-shadow:inset 0 -8px 0 rgba(0,0,0,.18), inset 0 3px 0 rgba(255,255,255,.35), 0 4px 0 rgba(0,0,0,.5);transform:scale(1);}
}
/* Lego stud burst */
.bolt{
  position:fixed;pointer-events:none;z-index:900;
  width:18px;height:18px;border-radius:50%;
  background:radial-gradient(circle at 35% 30%, rgba(255,255,255,.85) 0 30%, transparent 35%), var(--lego-yellow);
  border:2px solid var(--lego-black);
  box-shadow:0 0 12px var(--lego-yellow);
  animation:boltFly 1.1s ease-out forwards;
}
.bolt.red{background:radial-gradient(circle at 35% 30%, rgba(255,255,255,.85) 0 30%, transparent 35%), var(--lego-red);box-shadow:0 0 12px var(--lego-red);}
.bolt.green{background:radial-gradient(circle at 35% 30%, rgba(255,255,255,.85) 0 30%, transparent 35%), var(--lego-green);box-shadow:0 0 12px var(--lego-green);}
@keyframes boltFly{
  0%{opacity:1;transform:translate(0,0) scale(.5) rotate(0);}
  60%{opacity:1;transform:translate(var(--dx,0),var(--dy,-80px)) scale(1.2) rotate(180deg);}
  100%{opacity:0;transform:translate(var(--dx,0),var(--dy,-160px)) scale(.5) rotate(360deg);}
}

/* ===== MODAL ===== */
.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:2000;justify-content:center;align-items:center;}
.modal.show{display:flex;}
.modal-content{

function makeDeskEl(idx, isIsland){
  const d = document.createElement('div');
  const seatedName = state.seats[idx];
  d.className = 'desk' + (seatedName ? ' seated' : ' empty');
  d.dataset.idx = idx;

  if(typeof idx === 'number'){
    const h = houseOfDesk(idx);
    if(h){ d.style.setProperty('--h-a', h.a); d.style.setProperty('--h-b', h.b); }
  }

  if(seatedName){
    const xp = state.xp[seatedName]||0;
    const lvl = document.createElement('div'); lvl.className='desk-lvl'; lvl.textContent='L'+levelOf(xp); d.appendChild(lvl);
    const xpb = document.createElement('div'); xpb.className='desk-xp'; xpb.textContent=xp; d.appendChild(xpb);
    const rowIdx = typeof idx === 'number' ? Math.floor(idx/COLS) : 0;
    d.appendChild(makeAvatar(seatedName, true, SABER_FOR_ROW[rowIdx] || '#39FF80'));
    const nm = document.createElement('div'); nm.className='desk-name'; nm.textContent=seatedName.trim(); d.appendChild(nm);
    const bar = document.createElement('div'); bar.className='desk-xpbar';
    const fill = document.createElement('div'); fill.style.width = (xpInLevel(xp)/XP_PER_LEVEL*100)+'%';
    bar.appendChild(fill); d.appendChild(bar);

    if(typeof idx === 'number'){
      const h = houseOfDesk(idx);
      if(h){
        const chip = document.createElement('div');
        chip.className = 'house-chip';
        chip.title = h.name;
        chip.innerHTML = houseCrestSVG(h);
        d.appendChild(chip);
      }
    }

    const isl = document.createElement('button');
    isl.className='island-btn';
    isl.textContent = isIsland ? 'RETURN' : 'SITH';
    isl.addEventListener('click', function(ev){
      ev.stopPropagation();
      toggleIsland(seatedName);
    });
    d.appendChild(isl);

    (function(n){ d.addEventListener('click', function(){ selectScholar(n); }); })(seatedName);
    (function(i,n){
      d.addEventListener('dblclick', function(){
        delete state.seats[i];
        if(state.selected===n) state.selected=null;
        save(); render();
      });
    })(idx, seatedName);
  } else {
    const num = document.createElement('div');
    num.textContent='POD ' + (typeof idx === 'number' ? idx+1 : idx);
    d.appendChild(num);
  }

  if(!isIsland){
    d.addEventListener('dragover', function(e){ e.preventDefault(); d.classList.add('drag-over'); });
    d.addEventListener('dragleave', function(){ d.classList.remove('drag-over'); });
    (function(i){
      d.addEventListener('drop', function(e){
        e.preventDefault();
        d.classList.remove('drag-over');
        const name = e.dataTransfer.getData('text/plain');
        if(!name) return;
        state.island = state.island.filter(function(s){return s!==name;});
        const prev = deskOfScholar(name);
        if(prev !== undefined) delete state.seats[prev];
        if(state.seats[i] && prev !== undefined){
          state.seats[prev] = state.seats[i];
        }
        state.seats[i] = name;
        save(); render();
      });
    })(idx);
  }
  return d;
}


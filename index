        '<div class="house-sub">' + h.school + ' &mdash; <em>"' + h.motto + '"</em> ' + h.mottoEn + '</div>' +
      '</div>' +
      '<div class="house-score">' + houseXp + ' FP</div>';
    rowDiv.appendChild(banner);

    const desks = document.createElement('div');
    desks.className = 'house-desks';
    for(let col=0; col<7; col++){
      if(col===3){
        const a = document.createElement('div'); a.className='aisle';
        desks.appendChild(a);
        continue;
      }
      const idx = rowIdx * COLS + (col<3 ? col : col-1);
      const name = state.seats[idx];
      if(name && state.island.indexOf(name)>=0){
        const tmp = state.seats[idx];
        delete state.seats[idx];
        desks.appendChild(makeDeskEl(idx, false));
        state.seats[idx] = tmp;
      } else {
        desks.appendChild(makeDeskEl(idx, false));
      }
    }
    rowDiv.appendChild(desks);
    wrap.appendChild(rowDiv);
  });
}

function computeHouseXp(rowIdx){
  let total = 0;
  for(let col=0; col<COLS; col++){
    const idx = rowIdx*COLS + col;
    const name = state.seats[idx];
    if(name && state.island.indexOf(name)<0){ total += (state.xp[name]||0); }
  }
  return total;
}

function renderIsland(){
  const z = document.getElementById('islandZone');
  const row = document.getElementById('islandRow');
  row.innerHTML = '';
  if(state.island.length === 0){ z.classList.add('empty'); return; }
  z.classList.remove('empty');
  state.island.forEach(function(name){
    let idx = deskOfScholar(name);
    if(idx === undefined){ idx = 'island-'+name; state.seats[idx] = name; }
    row.appendChild(makeDeskEl(idx, true));
  });
}
function toggleIsland(name){
  const i = state.island.indexOf(name);
  if(i>=0){ state.island.splice(i,1); toast(name.trim()+' RETURNS TO THE LIGHT'); }
  else    { state.island.push(name);    toast(name.trim()+' SENT TO SITH HOLDING', 'bad'); }
  save(); render();
}
function clearIsland(){
  if(state.island.length===0) return;
  state.island = []; save(); render(); toast('SITH HOLDING CLEARED');
}

function selectScholar(name){ state.selected = name; renderSelected(); }
function renderSelected(){
  const info = document.getElementById('selectedInfo');
  const name = state.selected;
  if(!name){
    info.innerHTML = '<div style="font-family:\'Fredoka\',sans-serif;font-size:16px;color:var(--lego-gray-dk);padding-top:40px;font-weight:600;">Select a padawan<br>to begin training</div>';
    return;
  }
  const xp = state.xp[name]||0;
  const lvl = levelOf(xp);
  const inLvl = xpInLevel(xp);
  const pct = (inLvl/XP_PER_LEVEL)*100;
  const h = houseOfScholar(name);
  let houseLine = '';
  if(h){
    houseLine = '<span class="house-tag" style="--h-a:'+h.a+';--h-b:'+h.b+';">'+h.name+'</span>';
  }
  info.innerHTML =
    '<div class="name">'+name.trim()+'</div>' +
    '<div class="rank-label">'+rankOf(xp)+' &bull; LVL '+lvl+'</div>' +
    houseLine +
    '<div class="stats">'+xp+' FORCE POINTS</div>' +
    '<div class="xp-bar-big"><div style="width:'+pct+'%"></div><div class="lbl">'+inLvl+' / '+XP_PER_LEVEL+'</div></div>';
}
function renderTrackerBtns(){
  const pos = document.getElementById('posBtns');
  const neg = document.getElementById('negBtns');
  pos.innerHTML = ''; neg.innerHTML = '';
  POS_CATS.forEach(function(cat){
    const b = document.createElement('button');
    b.className = 'btn ' + (cat.kind || 'good');
    b.innerHTML = cat.label + '<br>+' + cat.pts;
    b.addEventListener('click', function(ev){ award(cat, ev); });
    pos.appendChild(b);
  });
  NEG_CATS.forEach(function(cat){
    const b = document.createElement('button');
    b.className = 'btn bad';
    b.innerHTML = cat.label + '<br>' + cat.pts;
    b.addEventListener('click', function(ev){ award(cat, ev); });
    neg.appendChild(b);
  });
}
function award(cat, ev){
  if(!state.selected){ toast('SELECT A PADAWAN!', 'bad'); return; }
  const name = state.selected;
  const prevLvl = levelOf(state.xp[name]||0);
  state.xp[name] = Math.max(0, (state.xp[name]||0) + cat.pts);
  const newLvl = levelOf(state.xp[name]);
  state.log.unshift({t:new Date().toLocaleTimeString(), name:name, label:cat.full, pts:cat.pts});
  if(state.log.length > 200) state.log.pop();
  toast(name.trim()+'  '+(cat.pts>0?'+':'')+cat.pts+' FP', cat.pts<0 ? 'bad' : (cat.kind||''));
  if(ev){ bolt(ev.clientX, ev.clientY, cat.pts<0 ? 'red' : 'green'); }
  if(newLvl > prevLvl){
    setTimeout(function(){ toast('★ RANK UP! '+name.trim()+' → '+rankOf(state.xp[name])+' ★', 'gold'); }, 700);
    const deskIdx = deskOfScholar(name);
    if(deskIdx !== undefined){
      const desk = document.querySelector('.desk[data-idx="'+deskIdx+'"]');
      if(desk){
        desk.classList.add('levelup');
        const r = desk.getBoundingClientRect();
        bolt(r.left + r.width/2, r.top + r.height/2, 'green');
        setTimeout(function(){desk.classList.remove('levelup');}, 1200);
      }
    }
  }
  save(); render();
}
function renderLog(){
  const l = document.getElementById('log');
  if(state.log.length===0){ l.innerHTML='<div style="opacity:.6;text-align:center;">~ holocron quiet ~</div>'; return; }
  l.innerHTML = state.log.slice(0,40).map(function(e){
    const cls = e.pts>0?'pos':'neg';
    return '<div class="log-entry">['+e.t+'] <b>'+e.name.trim()+'</b> '+e.label+
      ' <span class="'+cls+'">('+(e.pts>0?'+':'')+e.pts+')</span></div>';
  }).join('');
}
function renderLeaderboard(){
  const lb = document.getElementById('leaderboard');
  const rows = HOUSES.map(function(h, i){ return {h:h, xp:computeHouseXp(i)}; });
  rows.sort(function(a,b){ return b.xp - a.xp; });
  lb.innerHTML = rows.map(function(r){
    return '<div class="leader-row" style="--h-a:'+r.h.a+';--h-b:'+r.h.b+';">' +
      '<span class="swatch"></span>' +
      '<span>'+r.h.name+'</span>' +
      '<span class="pts">'+r.xp+' FP</span>' +
      '</div>';
  }).join('');
  const top = rows[0];
  if(top){ document.getElementById('topHouseChip').textContent = '★ ' + top.h.name; }
}
function renderHud(){
  const total = SCHOLARS.reduce(function(a,s){return a+(state.xp[s]||0);},0);
  document.getElementById('totalXp').textContent = total;
  document.getElementById('classLvl').textContent = Math.floor(total / (XP_PER_LEVEL*5)) + 1;
  let seated = 0;
  Object.keys(state.seats).forEach(function(k){
    if(typeof k === 'string' && k.indexOf('island-')===0) return;
    if(state.island.indexOf(state.seats[k]) >= 0) return;
    if(state.seats[k]) seated++;
  });
  document.getElementById('seatedCount').textContent = seated;
}

function autoSeat(){
  const seatedSet = new Set(Object.values(state.seats));
  const unseated = SCHOLARS.filter(function(s){ return !seatedSet.has(s); });
  for(let i=0;i<DESK_COUNT && unseated.length;i++){
    if(!state.seats[i]){ state.seats[i] = unseated.shift(); }
  }
  save(); render(); toast('DEPLOYED!', 'gold');
}
function shuffleSeats(){
  const all = SCHOLARS.slice().sort(function(){return Math.random()-0.5;});
  state.seats = {}; state.island = [];
  for(let i=0;i<DESK_COUNT && i<all.length;i++){ state.seats[i] = all[i]; }
  save(); render(); toast('HYPERSPACE!', 'gold');
}
function clearSeats(){
  if(!confirm('Clear the entire training deck?')) return;
  state.seats = {}; state.selected = null; state.island = [];
  save(); render();
}
function resetXP(){
  if(!confirm('Reset all Force Points and the holocron log?')) return;
  SCHOLARS.forEach(function(s){ state.xp[s]=0; });
  state.log = [];
  save(); render();
}

let lastExport = {name:'', body:''};
function activeDeskOf(name){
  const k = deskOfScholar(name);
  if(k === undefined) return null;
  if(typeof k === 'string' && k.indexOf('island-')===0) return null;
  return +k;
}
function exportMD(){
  const lines = [];
  lines.push("# Saint Mary's LEGO Jedi Academy — Master Gonzalez");
  lines.push('');
  lines.push('*A long time ago, in a 6th grade classroom far, far away…*');
  lines.push('Generated: ' + new Date().toLocaleString());
  lines.push('');
  lines.push('## Factions');
  lines.push('');
  HOUSES.forEach(function(h, i){
    lines.push('### Row ' + (i+1) + ' — ' + h.name);
    lines.push('- **Creed:** ' + h.school);
    lines.push('- **Motto:** *"' + h.motto + '"* ' + h.mottoEn);
    lines.push('- **Colors:** `' + h.a + '` / `' + h.b + '`');
    lines.push('- **Faction Force:** ' + computeHouseXp(i) + ' FP');
    lines.push('');
  });
  lines.push('## Training Deck (4 rows × 6 pods, center aisle)');
  lines.push('');
  lines.push('| Row | A-1 | A-2 | A-3 | || | B-1 | B-2 | B-3 |');
  lines.push('|-----|-----|-----|-----|----|-----|-----|-----|');
  for(let row=0; row<ROWS; row++){
    const cells = [];
    for(let col=0; col<COLS; col++){
      const idx = row*COLS + col;
      const name = state.seats[idx];
      const onIsland = name && state.island.indexOf(name)>=0;
      cells.push(name && !onIsland ? name.trim()+' (L'+levelOf(state.xp[name]||0)+')' : '*empty*');
    }
    lines.push('| ' + (row+1) + ' | ' + cells.slice(0,3).join(' | ') + ' | || | ' + cells.slice(3).join(' | ') + ' |');
  }
  if(state.island.length){
    lines.push('');
    lines.push('### ~~ SITH HOLDING ~~');
    state.island.forEach(function(n){
      lines.push('- ' + n.trim() + ' (' + rankOf(state.xp[n]||0) + ' / ' + (state.xp[n]||0) + ' FP)');
    });
  }
  lines.push('');
  lines.push('## Padawan Ranks');
  lines.push('');
  lines.push('| Rank | Padawan | Faction | Jedi Rank | FP | Pod |');
  lines.push('|------|---------|---------|-----------|-----|-----|');
  const ranked = SCHOLARS.slice().sort(function(a,b){ return (state.xp[b]||0)-(state.xp[a]||0); });
  ranked.forEach(function(s, i){
    const d = activeDeskOf(s);
    const onIsland = state.island.indexOf(s) >= 0;
    const seat = onIsland ? 'SITH' : (d !== null ? (d+1) : '—');
    const h = (d !== null) ? houseOfDesk(d) : null;
    const houseLbl = h ? h.name : '—';
    lines.push('| '+(i+1)+' | '+s.trim()+' | '+houseLbl+' | '+rankOf(state.xp[s]||0)+' | '+(state.xp[s]||0)+' | '+seat+' |');
  });
  lines.push('');
  lines.push('## Holocron Log (recent 50)');
  lines.push('');
  lines.push('| Time | Padawan | Category | FP |');
  lines.push('|------|---------|----------|-----|');
  state.log.slice(0,50).forEach(function(e){
    lines.push('| '+e.t+' | '+e.name.trim()+' | '+e.label+' | '+(e.pts>0?'+':'')+e.pts+' |');
  });
  lines.push('');
  lines.push('## Academies of the Galaxy');
  lines.push('');
  WORLD.forEach(function(w){
    lines.push('- **' + w.name + '** &mdash; ' + w.loc + ' &mdash; *"' + w.motto + '"*');
  });
  lastExport = {name:'lego_jedi_academy_report.md', body:lines.join('\n')};
  openModal('MARKDOWN TRANSMISSION', lastExport.body);
}
function exportCSV(){
  const rows = [];
  rows.push('Padawan,Faction,Jedi_Rank,FP,Pod,On_Sith_Hold,Total_Awards');
  const counts = {};
  state.log.forEach(function(e){ counts[e.name] = (counts[e.name]||0)+1; });
  SCHOLARS.forEach(function(s){
    const d = activeDeskOf(s);
    const onIsland = state.island.indexOf(s) >= 0;
    const h = (d !== null) ? houseOfDesk(d) : null;
    rows.push([
      s.trim(),
      h ? h.name : '',
      rankOf(state.xp[s]||0),
      state.xp[s]||0,
      onIsland ? 'SITH' : (d !== null ? (d+1) : ''),
      onIsland ? 'yes' : 'no',
      counts[s]||0
    ].join(','));
  });
  rows.push('');
  rows.push('Faction,Creed,Motto,Faction_FP');
  HOUSES.forEach(function(h, i){
    rows.push(['"'+h.name+'"','"'+h.school+'"','"'+h.motto+'"', computeHouseXp(i)].join(','));
  });
  rows.push('');
  rows.push('Time,Padawan,Category,FP');
  state.log.forEach(function(e){
    rows.push([e.t,'"'+e.name.trim()+'"','"'+e.label+'"',e.pts].join(','));
  });
  lastExport = {name:'lego_jedi_academy_report.csv', body:rows.join('\n')};
  openModal('CSV TRANSMISSION', lastExport.body);
}
function openModal(title, body){
  document.getElementById('modalTitle').textContent = title;
  document.getElementById('modalBody').textContent = body;
  document.getElementById('modal').classList.add('show');
}
function closeModal(){ document.getElementById('modal').classList.remove('show'); }
function copyOutput(){ navigator.clipboard.writeText(lastExport.body).then(function(){ toast('TRANSMITTED!', 'gold'); }); }
function downloadOutput(){
  const blob = new Blob([lastExport.body], {type:'text/plain'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = lastExport.name; a.click();
}

function render(){
  renderRoster();
  renderHouseRows();
  renderIsland();
  renderSelected();
  renderLog();
  renderLeaderboard();
  renderHud();
}

load();
renderTrackerBtns();
renderWorldStrip();
renderMarquee();
render();
</script>
</body>
</html>

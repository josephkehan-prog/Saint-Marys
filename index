  max-height:50vh;overflow-y:auto;color:var(--lego-black);font-weight:500;
}
.modal-actions{margin-top:14px;display:flex;gap:10px;}

::-webkit-scrollbar{width:12px;height:12px;}
::-webkit-scrollbar-track{background:var(--lego-black);}
::-webkit-scrollbar-thumb{background:var(--lego-yellow);border-radius:6px;border:2px solid var(--lego-black);}

footer{

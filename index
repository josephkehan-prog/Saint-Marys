let state = {seats:{}, xp:{}, log:[], selected:null, island:[]};

function load(){
  try{
    const raw = localStorage.getItem(STORAGE_KEY);
    if(raw){ state = Object.assign(state, JSON.parse(raw)); }
  }catch(e){}
  if(!Array.isArray(state.island)) state.island = [];
  SCHOLARS.forEach(function(s){ if(!(s in state.xp)) state.xp[s] = 0; });
}
function save(){ localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }

function levelOf(xp){ return Math.floor(xp / XP_PER_LEVEL) + 1; }
function rankOf(xp){ const i = Math.min(RANKS.length-1, levelOf(xp)-1); return RANKS[i]; }
function xpInLevel(xp){ return xp % XP_PER_LEVEL; }
function deskOfScholar(name){ return Object.keys(state.seats).find(function(k){ return state.seats[k] === name; }); }
function houseOfDesk(idx){
  if(typeof idx === 'string') return null;
  const row = Math.floor((+idx) / COLS);
  return HOUSES[row] || null;
}
function houseOfScholar(name){
  const k = deskOfScholar(name);
  if(k === undefined) return null;
  return houseOfDesk(+k);
}


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Saint Mary's LEGO Star Wars Academy — Master Gonzalez</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Lilita+One&family=Bungee&display=swap" rel="stylesheet">
<style>
/* ===== LEGO PALETTE ===== */
:root{
  --lego-red:#C91A09;
  --lego-red-dk:#920B00;
  --lego-yellow:#F2CD37;
  --lego-yellow-dk:#C9A328;
  --lego-blue:#0055BF;
  --lego-blue-dk:#003A85;
  --lego-green:#237841;
  --lego-orange:#FE8A18;
  --lego-black:#05131D;
  --lego-white:#FFFFFF;
  --lego-cream:#FFF8DC;
  --lego-gray:#6C6E68;
  --lego-gray-lt:#A0A5A9;
  --lego-gray-dk:#3F4042;
  --lego-tan:#E4CD9E;
  --lego-brown:#583927;

  /* Saber trans colors */
  --saber-green:#39FF80;
  --saber-blue:#4FC3F7;
  --saber-red:#FF3D3D;
  --saber-purple:#D27DFF;

  /* Faction palettes (one per row) */
  --h1-a:#0055BF; --h1-b:#39FF80; /* JEDI ORDER — blue + green saber */
  --h2-a:#FE8A18; --h2-b:#F2CD37; /* REBEL ALLIANCE — orange + yellow */
  --h3-a:#3F4042; --h3-b:#A0A5A9; /* MANDALORIAN — beskar gray */
  --h4-a:#C91A09; --h4-b:#FFFFFF; /* RESISTANCE — red + white */

  --bg-a:#1E3A8A;
  --bg-b:#0F1E4D;
  --baseplate:#8B8E91;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{
  background:var(--bg-b);color:var(--lego-black);
  font-family:'Fredoka','Trebuchet MS',sans-serif;font-size:16px;font-weight:500;
  min-height:100vh;overflow-x:hidden;
}
body{
  background:
    /* faint stars (round, not pixel) */
    radial-gradient(circle 2px at 12% 18%, var(--lego-white) 99%, transparent),
    radial-gradient(circle 1.5px at 28% 9%, var(--lego-white) 99%, transparent),
    radial-gradient(circle 2px at 47% 22%, var(--saber-blue) 99%, transparent),
    radial-gradient(circle 1.5px at 68% 14%, var(--lego-white) 99%, transparent),
    radial-gradient(circle 2px at 82% 28%, var(--lego-yellow) 99%, transparent),
    radial-gradient(circle 2px at 93% 8%, var(--lego-white) 99%, transparent),
    radial-gradient(circle 1.5px at 7% 60%, var(--lego-white) 99%, transparent),
    radial-gradient(circle 2px at 22% 78%, var(--saber-purple) 99%, transparent),
    radial-gradient(circle 2px at 55% 88%, var(--lego-white) 99%, transparent),
    radial-gradient(circle 2px at 88% 72%, var(--saber-blue) 99%, transparent),
    /* nebula */
    radial-gradient(ellipse 50% 35% at 80% 25%, rgba(210,125,255,.22) 0%, transparent 60%),
    radial-gradient(ellipse 45% 30% at 18% 75%, rgba(79,195,247,.20) 0%, transparent 60%),
    /* sky */
    linear-gradient(180deg, #050a30 0%, var(--bg-b) 40%, var(--bg-a) 100%);
  background-attachment:fixed;
}

/* ===== LEGO BRICK HELPERS ===== */
/* A bar of "studs" — circles aligned across the top */
.studs{
  display:flex;justify-content:space-around;align-items:center;
  height:14px;padding:0 8px;
}
.studs .stud{
  width:14px;height:14px;border-radius:50%;
  background:radial-gradient(circle at 35% 30%, rgba(255,255,255,.7) 0 25%, transparent 30%),
             var(--stud-color, var(--lego-yellow));
  box-shadow:inset 0 -3px 0 rgba(0,0,0,.25), 1px 1px 0 rgba(0,0,0,.4);
  flex-shrink:0;
}

/* A brick container — flat block with studs on top */
.brick{
  position:relative;border-radius:6px;
  box-shadow:inset 0 -6px 0 rgba(0,0,0,.18), inset 0 2px 0 rgba(255,255,255,.25), 0 4px 0 rgba(0,0,0,.35), 0 8px 18px rgba(0,0,0,.4);
  background:var(--brick-color, var(--lego-yellow));
  color:var(--lego-black);
}
.brick::before{
  content:"";position:absolute;left:0;right:0;top:-12px;height:14px;
  background:
    radial-gradient(circle 6px at 12px center, var(--brick-color, var(--lego-yellow)) 99%, transparent) repeat-x,
    radial-gradient(circle 6px at 12px center, rgba(0,0,0,.25) 99%, transparent) repeat-x;
  background-position: 0 0, 0 2px;
  background-size: 24px 12px, 24px 12px;
  -webkit-mask-image:linear-gradient(180deg, #000 60%, transparent);
          mask-image:linear-gradient(180deg, #000 60%, transparent);
  pointer-events:none;
}

/* ===== HEADER ===== */
header{
  background:linear-gradient(180deg, var(--lego-red) 0%, var(--lego-red-dk) 100%);
  border-bottom:6px solid var(--lego-black);
  padding:30px 20px 18px 20px;
  box-shadow:0 8px 0 var(--lego-yellow), 0 14px 30px rgba(0,0,0,.5);
  position:relative;
}
/* studs along top of header */
header::before{
  content:"";position:absolute;top:6px;left:0;right:0;height:18px;
  background:
    radial-gradient(circle 8px at 16px 9px, #DC4A3A 99%, transparent) repeat-x;
  background-size:32px 18px;
  filter:drop-shadow(0 -3px 0 rgba(0,0,0,.3)) drop-shadow(0 2px 0 rgba(255,255,255,.2));
}
.banner{
  display:grid;grid-template-columns:auto 1fr auto;gap:20px;align-items:center;
  max-width:1700px;margin:0 auto;
}
.crest{
  width:108px;height:108px;
  filter:drop-shadow(3px 4px 0 var(--lego-black)) drop-shadow(0 0 20px var(--lego-yellow));
}
.crest svg{width:100%;height:100%;}
.title-wrap{text-align:center;color:var(--lego-white);}
h1{
  font-family:'Lilita One','Fredoka',sans-serif;
  font-size:36px;letter-spacing:2px;line-height:1;
  color:var(--lego-yellow);
  text-shadow:
    3px 0 var(--lego-black), -3px 0 var(--lego-black), 0 3px var(--lego-black), 0 -3px var(--lego-black),
    4px 4px 0 var(--lego-black), 6px 7px 0 rgba(0,0,0,.35);
  margin-bottom:6px;
}
.subtitle{font-size:20px;color:var(--lego-cream);font-style:italic;font-weight:600;}
.subtitle em{color:var(--lego-yellow);}
.subtitle-en{font-size:14px;color:var(--lego-white);letter-spacing:2px;margin-top:4px;font-weight:700;}

.hud{display:flex;gap:8px;flex-direction:column;align-items:flex-end;}
.hud .chip{
  background:var(--lego-yellow);color:var(--lego-black);
  padding:8px 14px;border-radius:18px;
  font-family:'Fredoka',sans-serif;font-weight:700;font-size:12px;letter-spacing:1px;
  border:3px solid var(--lego-black);
  box-shadow:0 4px 0 rgba(0,0,0,.3);
}
.hud .chip.lead{background:var(--lego-green);color:var(--lego-white);}

/* Planets strip */
.world-strip{
  margin-top:18px;padding:10px 8px 6px 8px;
  background:linear-gradient(180deg, var(--lego-black) 0%, #11203d 100%);
  border-top:4px solid var(--lego-yellow);border-bottom:4px solid var(--lego-yellow);
  display:flex;justify-content:center;gap:10px;flex-wrap:wrap;position:relative;
}
.world-strip::before{
  content:"~ ACADEMIES OF THE GALAXY ~";
  position:absolute;top:-13px;left:50%;transform:translateX(-50%);
  background:var(--lego-yellow);color:var(--lego-black);
  font-family:'Lilita One',sans-serif;font-size:12px;letter-spacing:2px;
  padding:3px 14px;border:3px solid var(--lego-black);border-radius:14px;
}
.world-item{
  display:flex;flex-direction:column;align-items:center;gap:2px;
  padding:6px 8px;min-width:128px;
  border:3px solid var(--lego-black);border-radius:10px;
  background:var(--lego-white);
  position:relative;
  box-shadow:0 3px 0 rgba(0,0,0,.4);
}
.world-item .mini-crest{width:40px;height:44px;}
.world-item .mini-crest svg{width:100%;height:100%;}
.world-item .mini-name{
  font-family:'Lilita One',sans-serif;font-size:10px;letter-spacing:1px;
  color:var(--lego-black);text-align:center;line-height:1.4;
}
.world-item .mini-loc{font-family:'Fredoka',sans-serif;font-size:13px;color:var(--lego-gray-dk);font-weight:600;}
.world-item .mini-motto{font-family:'Fredoka',sans-serif;font-size:11px;color:var(--lego-blue);font-style:italic;text-align:center;line-height:1.1;font-weight:600;}

/* marquee */
.marquee{
  background:var(--lego-black);border-top:4px solid var(--lego-yellow);
  overflow:hidden;position:relative;padding:8px 0;
}
.marquee-label{
  position:absolute;left:0;top:0;bottom:0;
  background:var(--lego-yellow);color:var(--lego-black);
  font-family:'Lilita One',sans-serif;font-size:13px;letter-spacing:2px;padding:8px 14px;
  border-right:4px solid var(--lego-black);z-index:2;
}
.marquee-track{
  display:flex;gap:48px;white-space:nowrap;
  animation:slide 50s linear infinite;
  padding-left:160px;
  font-family:'Fredoka',sans-serif;font-size:16px;color:var(--lego-cream);font-weight:600;
}
.marquee-track span b{color:var(--lego-yellow);font-family:'Lilita One',sans-serif;font-size:13px;letter-spacing:1px;}
@keyframes slide{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ===== LAYOUT ===== */
main{
  display:grid;
  grid-template-columns: 280px 1fr 300px;
  gap:18px;padding:24px 18px 18px 18px;
  max-width:1700px;margin:0 auto;
}
.panel{
  --brick-color:var(--lego-yellow);
  background:var(--brick-color);
  border:4px solid var(--lego-black);border-radius:10px;
  padding:14px;color:var(--lego-black);
  box-shadow:inset 0 -8px 0 rgba(0,0,0,.18), inset 0 3px 0 rgba(255,255,255,.4), 0 6px 0 var(--lego-black), 0 12px 24px rgba(0,0,0,.5);
  position:relative;
}
.panel::before{
  content:"";position:absolute;left:6px;right:6px;top:-12px;height:14px;
  background:
    radial-gradient(circle 7px at 14px center, var(--brick-color) 99%, transparent) repeat-x;
  background-size:28px 14px;
  filter:drop-shadow(0 -2px 0 rgba(0,0,0,.35)) drop-shadow(0 2px 0 rgba(255,255,255,.4));
}
.panel h2{
  font-family:'Lilita One',sans-serif;
  font-size:18px;letter-spacing:2px;text-align:center;
  background:var(--lego-black);color:var(--lego-yellow);
  margin:-14px -14px 14px -14px;padding:10px;
  border-bottom:4px solid var(--lego-red);border-radius:6px 6px 0 0;
}

/* Left & right panel colors */
.panel.left{--brick-color:var(--lego-blue);color:var(--lego-white);}
.panel.left h2{background:var(--lego-yellow);color:var(--lego-black);border-bottom-color:var(--lego-red);}
.panel.right{--brick-color:var(--lego-red);color:var(--lego-white);}
.panel.right h2{background:var(--lego-yellow);color:var(--lego-black);border-bottom-color:var(--lego-black);}

/* ===== ROSTER ===== */
.roster{display:flex;flex-direction:column;gap:6px;max-height:78vh;overflow-y:auto;padding-right:4px;}
.scholar{
  background:var(--lego-white);color:var(--lego-black);
  padding:6px 10px;border:3px solid var(--lego-black);border-radius:8px;
  cursor:grab;display:flex;align-items:center;gap:10px;
  user-select:none;font-family:'Fredoka',sans-serif;font-size:16px;font-weight:600;
  box-shadow:0 4px 0 rgba(0,0,0,.5);
  transition:transform .08s;position:relative;
}
.scholar:hover{transform:translate(-1px,-2px);}
.scholar:active{cursor:grabbing;transform:translate(1px,2px);box-shadow:0 2px 0 rgba(0,0,0,.5);}
.scholar.seated{opacity:.4;}
.scholar.seated::after{
  content:"DEPLOYED";position:absolute;right:8px;top:50%;transform:translateY(-50%);
  font-family:'Lilita One',sans-serif;font-size:10px;color:var(--lego-green);
}
.scholar .lvl-badge{
  margin-left:auto;background:var(--lego-yellow);color:var(--lego-black);
  font-family:'Lilita One',sans-serif;font-size:11px;padding:3px 7px;border:2px solid var(--lego-black);border-radius:10px;
}
/* Lego minifig avatar wrapper */
.avatar{
  width:32px;height:36px;flex-shrink:0;
  filter:drop-shadow(0 1px 0 rgba(0,0,0,.4));
}
.avatar svg{width:100%;height:100%;}
.avatar.bounce{animation:bounce 2.4s ease-in-out infinite;}
@keyframes bounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-3px);}}

/* ===== CLASSROOM (= LEGO BASEPLATE) ===== */
.classroom-wrap{
  background:
    /* lego baseplate studs */
    radial-gradient(circle 5px at center, rgba(255,255,255,.18) 0 30%, rgba(0,0,0,.18) 32% 50%, transparent 52%) 0 0/24px 24px,
    linear-gradient(180deg, var(--baseplate) 0%, #6a6e72 100%);
  border:6px solid var(--lego-black);border-radius:14px;
  padding:22px 22px 18px 22px;position:relative;
  box-shadow:inset 0 0 0 4px var(--lego-yellow), inset 0 0 30px rgba(0,0,0,.3), 0 8px 0 var(--lego-red), 0 16px 36px rgba(0,0,0,.7);
}

/* Holo-screen above teacher desk */
.chalkboard{
  background:linear-gradient(180deg, var(--lego-blue) 0%, var(--lego-blue-dk) 100%);
  border:4px solid var(--lego-black);border-radius:10px;
  padding:14px;text-align:center;color:var(--lego-white);
  font-family:'Fredoka',sans-serif;font-size:18px;letter-spacing:1px;font-weight:600;
  box-shadow:inset 0 -6px 0 rgba(0,0,0,.3), inset 0 3px 0 rgba(255,255,255,.25), 0 4px 0 var(--lego-black);
  margin-bottom:14px;position:relative;
}
.chalkboard::before{
  /* studs on top */
  content:"";position:absolute;left:6px;right:6px;top:-12px;height:14px;
  background:radial-gradient(circle 7px at 14px center, var(--lego-blue) 99%, transparent) repeat-x;
  background-size:28px 14px;
  filter:drop-shadow(0 -2px 0 rgba(0,0,0,.4)) drop-shadow(0 2px 0 rgba(255,255,255,.35));
}
.chalkboard .title{
  font-family:'Lilita One',sans-serif;font-size:18px;color:var(--lego-yellow);
  letter-spacing:2px;display:block;margin-bottom:4px;
}

/* Teacher console */
.teacher-desk{
  background:linear-gradient(180deg, var(--lego-yellow) 0%, var(--lego-yellow-dk) 100%);
  border:4px solid var(--lego-black);border-radius:10px;
  padding:14px 12px;text-align:center;color:var(--lego-black);
  font-family:'Lilita One',sans-serif;font-size:18px;letter-spacing:2px;
  margin-bottom:18px;
  box-shadow:inset 0 -8px 0 rgba(0,0,0,.18), inset 0 3px 0 rgba(255,255,255,.4), 0 5px 0 var(--lego-black), 0 10px 0 var(--lego-red);
  position:relative;
}
.teacher-desk::before{
  content:"";position:absolute;left:6px;right:6px;top:-12px;height:14px;
  background:radial-gradient(circle 7px at 14px center, var(--lego-yellow) 99%, transparent) repeat-x;
  background-size:28px 14px;
  filter:drop-shadow(0 -2px 0 rgba(0,0,0,.4)) drop-shadow(0 2px 0 rgba(255,255,255,.4));
}
.saber-icon{
  display:inline-block;width:14px;height:18px;vertical-align:middle;
  background:var(--saber-green);border-radius:3px;
  box-shadow:0 0 10px var(--saber-green);
  border:1px solid var(--lego-black);
  animation:pulse 1.4s ease-in-out infinite;margin:0 6px;
}
@keyframes pulse{0%,100%{transform:scale(1);box-shadow:0 0 10px var(--saber-green);}50%{transform:scale(1.15);box-shadow:0 0 18px var(--saber-green);}}

/* Lego decorations flanking */
.sw-decor{position:absolute;width:80px;height:96px;pointer-events:none;z-index:3;filter:drop-shadow(2px 4px 0 rgba(0,0,0,.5));}
.sw-decor svg{width:100%;height:100%;}
.sw-decor-l{left:-32px;top:120px;animation:floatL 4s ease-in-out infinite;}
.sw-decor-r{right:-32px;top:90px;animation:floatR 4s ease-in-out infinite;}
@keyframes floatL{0%,100%{transform:translateY(0) rotate(-3deg);}50%{transform:translateY(-8px) rotate(3deg);}}
@keyframes floatR{0%,100%{transform:translateY(0) rotate(3deg);}50%{transform:translateY(-8px) rotate(-3deg);}}

.flyby{
  position:absolute;top:30px;left:-100px;width:90px;height:46px;
  z-index:4;pointer-events:none;animation:fly 14s linear infinite;
  filter:drop-shadow(2px 3px 0 rgba(0,0,0,.5));
}
.flyby svg{width:100%;height:100%;}
@keyframes fly{
  0%{left:-100px;top:30px;}
  100%{left:110%;top:80px;}
}

/* Faction row */
.house-row{
  margin-bottom:18px;position:relative;
  padding:10px 10px 14px 10px;border-radius:10px;
  border:4px solid var(--lego-black);
  background:linear-gradient(180deg, var(--h-a, var(--lego-blue)) 0%, rgba(0,0,0,.45) 100%);
  box-shadow:inset 0 -6px 0 rgba(0,0,0,.2), inset 0 3px 0 rgba(255,255,255,.18), 0 4px 0 rgba(0,0,0,.4);
}
.house-banner{
  display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:12px;
  background:var(--lego-white);
  border:3px solid var(--lego-black);border-radius:8px;
  padding:8px 12px;margin-bottom:10px;
  box-shadow:0 3px 0 rgba(0,0,0,.4);
}
.house-mascot{width:48px;height:50px;}
.house-mascot svg{width:100%;height:100%;}
.house-text{display:flex;flex-direction:column;line-height:1.15;}
.house-name{
  font-family:'Lilita One',sans-serif;font-size:16px;letter-spacing:2px;color:var(--h-a, var(--lego-blue));
}
.house-sub{font-family:'Fredoka',sans-serif;font-size:14px;color:var(--lego-gray-dk);font-weight:600;}
.house-sub em{color:var(--lego-black);font-style:italic;}
.house-score{
  font-family:'Lilita One',sans-serif;font-size:14px;
  background:var(--lego-yellow);color:var(--lego-black);
  padding:6px 12px;border:3px solid var(--lego-black);border-radius:16px;
  letter-spacing:1px;
  box-shadow:0 3px 0 rgba(0,0,0,.4);
}

.house-desks{
  display:grid;
  grid-template-columns: repeat(3, 1fr) 32px repeat(3, 1fr);
  gap:12px;
}
.aisle{
  background:repeating-linear-gradient(180deg, transparent 0 8px, rgba(255,205,55,.6) 8px 14px);
  border-left:3px dashed var(--lego-yellow);
  border-right:3px dashed var(--lego-yellow);
  border-radius:4px;
}

/* DESK = LEGO BRICK SEAT */
.desk{
  background:var(--lego-tan);color:var(--lego-black);
  border:3px solid var(--lego-black);border-radius:8px;
  padding:6px;position:relative;min-height:108px;
  display:flex;flex-direction:column;justify-content:center;align-items:center;
  font-family:'Fredoka',sans-serif;font-size:14px;text-align:center;font-weight:600;
  box-shadow:inset 0 -8px 0 rgba(0,0,0,.18), inset 0 3px 0 rgba(255,255,255,.35), 0 4px 0 rgba(0,0,0,.5);
  transition:transform .12s, box-shadow .12s;cursor:pointer;
}
.desk::after{
  /* stud row on top */
  content:"";position:absolute;left:4px;right:4px;top:-8px;height:12px;
  background:radial-gradient(circle 6px at 12px center, var(--lego-tan) 99%, transparent) repeat-x;
  background-size:24px 12px;
  filter:drop-shadow(0 -2px 0 rgba(0,0,0,.4)) drop-shadow(0 2px 0 rgba(255,255,255,.3));
}
.desk:hover{transform:translate(-1px,-2px);box-shadow:inset 0 -8px 0 rgba(0,0,0,.18), inset 0 3px 0 rgba(255,255,255,.35), 0 6px 0 rgba(0,0,0,.5);}
.desk.empty{
  background:rgba(255,255,255,.18);color:var(--lego-white);
  border:3px dashed var(--lego-yellow);
  box-shadow:none;
  font-family:'Lilita One',sans-serif;font-size:11px;letter-spacing:1px;cursor:default;
}
.desk.empty::after{display:none;}
.desk.drag-over{outline:4px solid var(--saber-green);outline-offset:3px;transform:scale(1.06);}
.desk-name{
  font-family:'Lilita One',sans-serif;font-size:13px;color:var(--lego-black);
  margin-top:2px;line-height:1;letter-spacing:1px;
}
.desk .mini-avatar{width:40px;height:44px;}
.desk-lvl{
  position:absolute;top:-8px;left:-8px;
  background:var(--h-a, var(--lego-blue));color:var(--lego-white);
  font-family:'Lilita One',sans-serif;font-size:10px;padding:3px 6px;
  border:2px solid var(--lego-black);border-radius:50%;min-width:24px;text-align:center;
  box-shadow:0 2px 0 rgba(0,0,0,.5);
}
.desk-xp{
  position:absolute;top:-8px;right:-8px;
  background:var(--lego-yellow);color:var(--lego-black);
  font-family:'Lilita One',sans-serif;font-size:9px;padding:3px 6px;
  border:2px solid var(--lego-black);border-radius:50%;min-width:24px;text-align:center;
  box-shadow:0 2px 0 rgba(0,0,0,.5);
}
.desk-xpbar{
  position:absolute;left:6px;right:6px;bottom:6px;height:8px;
  background:var(--lego-black);border:1px solid var(--lego-black);border-radius:4px;overflow:hidden;
}
.desk-xpbar > div{
  height:100%;
  background:linear-gradient(180deg, #fff 0%, var(--saber-green) 50%, #1ec45c 100%);
  box-shadow:0 0 8px var(--saber-green);transition:width .3s;
}
.desk .island-btn{
  position:absolute;bottom:-10px;right:-6px;
  background:var(--lego-red);color:var(--lego-white);

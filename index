  box-shadow:inset 0 0 40px rgba(255,61,61,.35);
}
.island-zone::before{
  content:"~~ SITH HOLDING ~~";position:absolute;top:-14px;left:50%;transform:translateX(-50%);
  background:var(--lego-red);color:var(--lego-white);
  font-family:'Lilita One',sans-serif;font-size:13px;letter-spacing:3px;
  padding:5px 14px;border:3px solid var(--lego-black);border-radius:14px;
  box-shadow:0 3px 0 rgba(0,0,0,.5);
}
.island-zone.empty::after{
  content:"CLICK [SITH] ON A BRICK TO BANISH TO THE DARK SIDE";
  display:block;text-align:center;color:var(--saber-red);
  font-family:'Lilita One',sans-serif;font-size:11px;letter-spacing:1px;padding:30px 10px;opacity:.9;
}
.island-zone .island-row{display:flex;flex-wrap:wrap;gap:18px;justify-content:center;align-items:center;}
.island-zone .desk{width:128px;height:108px;filter:drop-shadow(0 0 14px var(--saber-red));animation:float 3s ease-in-out infinite;}
